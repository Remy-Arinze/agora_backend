logging {
  level  = "info"
  format = "logfmt"
}

prometheus.scrape "agora_backend" {
  targets = [{
    __address__ = "backend:3000",
  }]
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
  metrics_path = "/metrics"
  
  bearer_token = env("METRICS_API_KEY") # We'll pass it via env or header. 
  # Actually, MetricsApiKeyGuard expects 'x-metrics-api-key' header.
  # Prometheus scrape doesn't easily support custom headers in the simple target config.
  # We should use 'prometheus.scrape' with 'http_client_config'.
}

# Correct way with custom header for MetricsApiKeyGuard
prometheus.scrape "agora_backend_secure" {
  targets = [{
    __address__ = "backend:3000",
  }]
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
  metrics_path = "/metrics"
  
  http_client_config {
    header = {
      "x-metrics-api-key" = [env("METRICS_API_KEY")],
    }
  }
}

prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = env("GRAFANA_CLOUD_PROMETHEUS_URL")
    basic_auth {
      username = env("GRAFANA_CLOUD_PROMETHEUS_USER")
      password = env("GRAFANA_CLOUD_PROMETHEUS_TOKEN")
    }
  }
}
